{# Date badge with relative time #}
{# Usage: {% set badgeDate = "2026-03-15" %}{% include "components/date-badge.njk" %} #}
{% if badgeDate %}
<span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded
  {% if badgeDate | isOverdue %}bg-exam/20 text-exam{% else %}bg-accent/10 text-accent{% endif %}">
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
  </svg>
  {{ badgeDate | formatDate }}
  <span class="opacity-75">({{ badgeDate | formatDateRelative }})</span>
</span>
{% endif %}
