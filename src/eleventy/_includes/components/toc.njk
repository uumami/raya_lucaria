{# Page Table of Contents - right sidebar with full collapse #}
<aside id="page-toc" class="hidden xl:block flex-shrink-0 border-l border-border toc-sidebar">
  {# Expanded state #}
  <div id="toc-expanded" class="sticky top-12 p-4 max-h-[calc(100vh-3rem)] overflow-y-auto w-56">
    <div class="flex items-center justify-between mb-3">
      <div class="text-xs text-text-muted uppercase tracking-wide">En esta pagina</div>
      <button id="toc-collapse-btn" class="p-1 rounded text-text-muted hover:text-accent hover:bg-bg-tertiary transition-colors" title="Colapsar">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
    <nav id="toc-nav" class="space-y-1 text-sm" aria-label="Tabla de contenidos">
      {# TOC is populated by JS from h2/h3 headings #}
    </nav>
  </div>
  {# Collapsed state — thin vertical tab #}
  <div id="toc-collapsed-tab" class="hidden sticky top-12">
    <button id="toc-expand-btn" class="p-2 text-text-muted hover:text-accent hover:bg-bg-tertiary transition-colors" title="Expandir tabla de contenidos">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7"/>
      </svg>
    </button>
  </div>
</aside>
