{# Page Table of Contents - right sidebar with collapse toggle #}
<aside id="page-toc" class="hidden xl:block w-56 flex-shrink-0 border-l border-border">
  <div class="sticky top-12 p-4 max-h-[calc(100vh-3rem)] overflow-y-auto">
    <div class="flex items-center justify-between mb-3">
      <div class="text-xs text-text-muted uppercase tracking-wide">En esta pagina</div>
      <button id="toc-collapse-btn" class="p-1 rounded text-text-muted hover:text-accent hover:bg-bg-tertiary transition-colors" title="Colapsar tabla de contenidos">
        <svg class="w-3.5 h-3.5 toc-collapse-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
    </div>
    <nav id="toc-nav" class="space-y-1 text-sm toc-links" aria-label="Tabla de contenidos">
      {# TOC is populated by JS from h2/h3 headings #}
    </nav>
  </div>
</aside>
