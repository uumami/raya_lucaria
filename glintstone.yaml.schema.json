{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "glintstone.yaml.schema.json",
  "title": "Glintstone Configuration",
  "description": "Configuration schema for the glintstone static site generator framework",
  "type": "object",
  "properties": {
    "site": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Site title displayed in header and browser tab" },
        "description": { "type": "string", "description": "Site subtitle/description" },
        "language": { "type": "string", "default": "es", "description": "Content language (BCP 47)" },
        "author": { "type": "string", "description": "Site author/institution" }
      },
      "required": ["name"]
    },
    "repository": {
      "type": "object",
      "description": "GitHub repository info. Auto-detected from git remote if omitted.",
      "properties": {
        "name": { "type": "string", "description": "Repository name (used as path prefix)" },
        "org": { "type": "string", "description": "GitHub organization or user" },
        "url": { "type": "string", "format": "uri", "description": "Full repository URL" }
      }
    },
    "source": {
      "type": "object",
      "properties": {
        "content_dir": { "type": "string", "default": "clase", "description": "Directory containing course content" },
        "exclude": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File/directory patterns to exclude from rendering"
        }
      }
    },
    "theme": {
      "type": "object",
      "properties": {
        "default": { "type": "string", "default": "raya-lucaria", "description": "Default theme name" },
        "available": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of available theme names"
        }
      }
    },
    "build": {
      "type": "object",
      "properties": {
        "output_dir": { "type": "string", "default": "_site", "description": "Build output directory" }
      }
    },
    "navigation": {
      "type": "object",
      "properties": {
        "show_breadcrumbs": { "type": "boolean", "default": true },
        "show_sidebar": { "type": "boolean", "default": true },
        "show_prev_next": { "type": "boolean", "default": true },
        "show_toc": { "type": "boolean", "default": true, "description": "Show page table of contents in right sidebar" }
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "search": { "type": "boolean", "default": true, "description": "Enable Pagefind search" },
        "theme_toggle": { "type": "boolean", "default": true },
        "font_toggle": { "type": "boolean", "default": true },
        "copy_code_button": { "type": "boolean", "default": true },
        "math": { "type": "boolean", "default": true, "description": "Enable KaTeX math rendering" },
        "mermaid": { "type": "boolean", "default": true, "description": "Enable Mermaid diagrams" },
        "docs": { "type": "boolean", "default": true, "description": "Enable built-in documentation" }
      }
    },
    "tasks": {
      "type": "object",
      "description": "Task aggregation configuration",
      "properties": {
        "pages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["homework", "exam", "project"] },
              "title": { "type": "string" },
              "slug": { "type": "string" }
            },
            "required": ["type", "title", "slug"]
          }
        }
      }
    }
  },
  "required": ["site"]
}
